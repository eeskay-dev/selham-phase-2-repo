# JIRA Integration Configuration
# Copy this file to .env and update with your JIRA instance details

# JIRA Instance Configuration
JIRA_URL=https://your-company.atlassian.net
JIRA_PROJECT=SPEC

# JIRA Authentication
# Generate API token at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_EMAIL=your-email@company.com
JIRA_TOKEN=your_jira_api_token

# Optional: Dry run mode (set to true to test without creating issues)
# DRY_RUN=false

# Custom Field Mappings (may need adjustment for your JIRA instance)
# These are common Atlassian field IDs, but verify with your admin:
# 
# Epic Name: customfield_10011
# Epic Link: customfield_10014  
# Story Points: customfield_10016
# Acceptance Criteria: customfield_10017
# Business Value: customfield_10020
# Target Release: customfield_10021
# Estimated Effort: customfield_10022
# Task Phase: customfield_10023
# Estimated Hours: customfield_10024
# Technical Complexity: customfield_10025
# Parallel Execution: customfield_10026