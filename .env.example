# JIRA Integration Configuration Example
# Copy to scripts/config/local.env and customize

# JIRA Configuration (Required)
JIRA_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_TOKEN=your-personal-access-token
JIRA_PROJECT=YOUR_PROJECT_KEY

# GitHub Configuration (Auto-detected in GitHub Actions)
GITHUB_REPO_URL=https://github.com/your-org/your-repo
GITHUB_BRANCH=main

# Issue Type Mappings (Optional - will auto-detect if not set)
ISSUE_TYPE_EPIC=Epic
ISSUE_TYPE_STORY=Story
ISSUE_TYPE_TASK=Sub-task
ISSUE_TYPE_BUG=Bug

# Execution Mode
DRY_RUN=true  # Set to "false" to create actual JIRA issues

# Generate API token at: https://id.atlassian.com/manage-profile/security/api-tokens

# Example values for reference:
# JIRA_URL=https://selham.atlassian.net
# JIRA_EMAIL=eeskay@zohomail.in  
# JIRA_PROJECT=SMM
JIRA_TOKEN=your_jira_api_token

# Optional: Dry run mode (set to true to test without creating issues)
# DRY_RUN=false

# Custom Field Mappings (may need adjustment for your JIRA instance)
# These are common Atlassian field IDs, but verify with your admin:
# 
# Epic Name: customfield_10011
# Epic Link: customfield_10014  
# Story Points: customfield_10016
# Acceptance Criteria: customfield_10017
# Business Value: customfield_10020
# Target Release: customfield_10021
# Estimated Effort: customfield_10022
# Task Phase: customfield_10023
# Estimated Hours: customfield_10024
# Technical Complexity: customfield_10025
# Parallel Execution: customfield_10026