# JIRA Integration Tool - Generic .gitignore

# Local configuration files (contains sensitive credentials)
scripts/config/local.env
*.env
.env*

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
*.log
logs/

# Temporary files
temp/
tmp/
*.tmp

# JIRA sync temporary directories
jira_sync_*/

# Project-specific specs (users should add their own)
specs/*
!specs/example-feature/

# Backup files
*.bak
*~